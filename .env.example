PORT=3000

# Primary image generation provider
REPLICATE_API_TOKEN=

# Optional text/image description provider
OPENAI_API_KEY=

# Optional image provider
GOOGLE_API_KEY=

# Optional beta API protection
BETA_TOKEN=

# Public base URL used when assets must be reachable outside localhost
PUBLIC_BASE_URL=http://localhost:3000

# Optional CORS allowlist, comma-separated
ALLOWED_ORIGINS=http://localhost:3000

# Legacy proxy provider, only if used
API_BASE_URL=
API_KEY=
